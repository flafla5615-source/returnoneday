rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function hasUserProfile() {
      return isAuth() && exists(/databases/$(database)/documents/users/$(uid()));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    // active status regardless of role
    function isActive() {
      return hasUserProfile() && getUserData().status == 'active';
    }

    function isAdmin() {
      return hasUserProfile() && getUserData().role == 'admin' && getUserData().status == 'active';
    }

    function isActiveManager() {
      return hasUserProfile() && getUserData().role == 'branch_manager' && getUserData().status == 'active';
    }

    function isManagerOfBranch(branchId) {
      return isActiveManager() && branchId in getUserData().branchIds;
    }

    function getReportData(reportId) {
      return get(/databases/$(database)/documents/dailyReports/$(reportId)).data;
    }

    function reportExists(reportId) {
      return exists(/databases/$(database)/documents/dailyReports/$(reportId));
    }

    function isEditableReportStatus(status) {
      return status in ['draft', 'revision_required'];
    }

    // ── KST 기준 보고일 범위 검증 (branch_manager 신규 생성 전용) ─────────────
    // reportDate("YYYY-MM-DD")를 UTC 자정 기준 "일수(day index)"로 변환하고,
    // request.time(UTC)을 KST(+9h)로 보정한 뒤 같은 방식으로 일수를 구해 비교한다.
    // 두 값 모두 "에폭 이후 며칠째"라는 동일한 정수 단위이므로 타임존 보정 없이
    // 직접 비교할 수 있다.
    function reportDateDayIndex(dateStr) {
      let p = dateStr.split('-');
      return int(timestamp.date(int(p[0]), int(p[1]), int(p[2])).toMillis() / 86400000);
    }

    function kstTodayDayIndex() {
      return int((request.time.toMillis() + 9 * 3600 * 1000) / 86400000);
    }

    // branch_manager는 오늘 또는 전일(KST)만 새 보고서를 생성할 수 있다.
    function isWithinManagerReportDateRange(dateStr) {
      let idx = reportDateDayIndex(dateStr);
      let todayIdx = kstTodayDayIndex();
      return idx >= todayIdx - 1 && idx <= todayIdx;
    }

    function canManagerTransitionReportStatus(currentStatus, nextStatus) {
      return (currentStatus == 'draft' && nextStatus in ['draft', 'submitted']) ||
        (currentStatus == 'revision_required' && nextStatus in ['revision_required', 'submitted']);
    }

    function canManagerEditReport(reportId) {
      return isActiveManager()
        && getReportData(reportId).branchId in getUserData().branchIds
        && isEditableReportStatus(getReportData(reportId).status);
    }

    function isAbnormalSubmittedReport(data) {
      return data.status == 'submitted'
        && data.activeMembers == null
        && data.inquiries == null
        && data.ptConsultations == null
        && data.ptRegistrations == null
        && data.reRegistrations == null
        && data.comebackMembers == null
        && data.happyCalls == null;
    }

    function canManagerReopenAbnormalSubmittedReport() {
      return isActiveManager()
        && resource.data.branchId in getUserData().branchIds
        && isAbnormalSubmittedReport(resource.data)
        && request.resource.data.status == 'draft'
        && request.resource.data.branchId == resource.data.branchId
        && request.resource.data.reportDate == resource.data.reportDate
        && request.resource.data.writerUid == resource.data.writerUid
        && request.resource.data.id == resource.data.id
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
    }

    function validIssueData(reportId, data) {
      return data.reportId == reportId
        && data.branchId == getReportData(reportId).branchId
        && data.reportDate == getReportData(reportId).reportDate
        && data.type in ['claim', 'staff', 'facility']
        && data.severity in ['low', 'medium', 'high', 'critical']
        && data.status in ['open', 'in_progress', 'resolved']
        && data.description is string;
    }

    function validCampaignResultData(reportId, data) {
      return data.reportId == reportId
        && data.branchId == getReportData(reportId).branchId
        && data.reportDate == getReportData(reportId).reportDate
        && data.campaignId is string
        && data.metrics is map;
    }

    function validMemberData(data) {
      return data.keys().hasOnly([
          'id', 'branchId', 'branchName', 'name', 'phone', 'status',
          'startDate', 'endDate', 'lastVisitDate', 'productName',
          'managerName', 'memo', 'source', 'sourceFileName',
          'createdAt', 'updatedAt'
        ])
        && data.id is string
        && data.branchId is string
        && data.branchName is string
        && data.name is string
        && data.phone is string
        && data.status in ['active', 'expiring', 'expired', 'unregistered', 'unknown']
        && data.source == 'bodycodi_excel'
        && !('password' in data);
    }

    function validSatisfactionData(data) {
      return data.keys().hasOnly([
          'id', 'memberId', 'branchId', 'branchName', 'memberName', 'phone',
          'responseDate', 'score', 'responseText', 'needsFollowUp',
          'followUpStatus', 'memo', 'source', 'sourceFileName',
          'createdAt', 'updatedAt'
        ])
        && data.id is string
        && data.branchId is string
        && data.branchName is string
        && data.memberName is string
        && data.phone is string
        && data.needsFollowUp is bool
        && data.followUpStatus in ['pending', 'in_progress', 'done']
        && data.source == 'bodycodi_excel'
        && !('password' in data);
    }

    function validMemberImportJobData(data) {
      return data.keys().hasOnly([
          'id', 'importType', 'fileName', 'uploadedByUid', 'uploadedByRole',
          'branchId', 'branchName', 'totalRows', 'validRows', 'invalidRows',
          'status', 'createdAt', 'updatedAt'
        ])
        && data.id is string
        && data.importType in ['members', 'satisfaction']
        && data.fileName is string
        && data.uploadedByUid == uid()
        && data.uploadedByRole in ['admin', 'branch_manager']
        && data.totalRows is int
        && data.validRows is int
        && data.invalidRows is int
        && data.status in ['preview', 'imported', 'failed'];
    }

    // ─── users ───────────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read their own document (any status); admins can read all
      allow read: if isAuth() && (uid() == userId || isAdmin());

      // Only admins can change role, status, branchIds
      allow update: if isAdmin() ||
        (isAuth() && uid() == userId
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'status', 'active', 'branchIds'])
          && !('password' in request.resource.data));

      // New user creates own document on signup — must be branch_manager/pending
      allow create: if isAuth() && uid() == userId
        && request.resource.data.keys().hasOnly([
          'uid', 'name', 'email', 'role', 'status', 'active', 'branchIds',
          'createdAt', 'updatedAt'
        ])
        && request.resource.data.uid == uid()
        && request.resource.data.role == 'branch_manager'
        && request.resource.data.status == 'pending'
        && request.resource.data.branchIds is list
        && request.resource.data.branchIds.size() == 0
        && !('password' in request.resource.data);

      allow delete: if isAdmin();
    }

    // ─── branches ─────────────────────────────────────────────────────────
    match /branches/{branchId} {
      allow read: if isAdmin() || isManagerOfBranch(branchId);
      allow write: if isAdmin();
    }

    // ─── dailyReports ─────────────────────────────────────────────────────
    match /dailyReports/{reportId} {
      allow get: if isAdmin() ||
        (isActiveManager()
          && (!reportExists(reportId) || resource.data.branchId in getUserData().branchIds));

      allow list: if isAdmin() ||
        (isActiveManager() && resource.data.branchId in getUserData().branchIds);

      // admin: 보고일 이동(moveReportDate) 시 새 날짜 문서를 생성하기 위해 필요.
      // branch_manager: 오늘/전일(KST)만 신규 생성 가능, 그 외 필드 제약은 기존과 동일.
      allow create: if isAdmin() ||
        (isActiveManager()
          && request.resource.data.branchId in getUserData().branchIds
          && request.resource.data.writerUid == uid()
          && request.resource.data.id == reportId
          // reportId must follow {branchId}_{YYYY-MM-DD}
          && reportId == request.resource.data.branchId + '_' + request.resource.data.reportDate
          && request.resource.data.status == 'draft'
          && isWithinManagerReportDateRange(request.resource.data.reportDate));

      allow update: if
        isAdmin() ||
        (isActiveManager()
          && resource.data.branchId in getUserData().branchIds
          && isEditableReportStatus(resource.data.status)
          && request.resource.data.branchId == resource.data.branchId
          && request.resource.data.reportDate == resource.data.reportDate
          && request.resource.data.writerUid == resource.data.writerUid
          && request.resource.data.id == resource.data.id
          && canManagerTransitionReportStatus(resource.data.status, request.resource.data.status)) ||
        canManagerReopenAbnormalSubmittedReport();

      allow delete: if isAdmin();

      // Sub-collection: issues
      match /issues/{issueId} {
        allow read: if isAdmin() ||
          (isActiveManager()
            && get(/databases/$(database)/documents/dailyReports/$(reportId)).data.branchId
               in getUserData().branchIds);
        allow create, update: if isAdmin() ||
          (canManagerEditReport(reportId) && validIssueData(reportId, request.resource.data));
        allow delete: if isAdmin() ||
          (canManagerEditReport(reportId) && resource.data.reportId == reportId);
      }
    }

    // ─── issues (top-level for admin queries) ─────────────────────────────
    match /issues/{issueId} {
      allow read: if isAdmin() ||
        (isActiveManager() && resource.data.branchId in getUserData().branchIds);
      allow create, update: if isAdmin() ||
        (request.resource.data.reportId is string
          && canManagerEditReport(request.resource.data.reportId)
          && validIssueData(request.resource.data.reportId, request.resource.data));
      allow delete: if isAdmin() ||
        (resource.data.reportId is string
          && canManagerEditReport(resource.data.reportId)
          && resource.data.branchId == getReportData(resource.data.reportId).branchId);
    }

    // ─── campaigns ────────────────────────────────────────────────────────
    // Only active users (admin or active manager) can read campaigns.
    // Pending / suspended users are excluded.
    match /campaigns/{campaignId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // ─── campaignResults ─────────────────────────────────────────────────
    match /campaignResults/{resultId} {
      allow read: if isAdmin() ||
        (isActiveManager() && resource.data.branchId in getUserData().branchIds);
      allow create, update: if isAdmin() ||
        (request.resource.data.reportId is string
          && canManagerEditReport(request.resource.data.reportId)
          && validCampaignResultData(request.resource.data.reportId, request.resource.data));
      allow delete: if isAdmin() ||
        (resource.data.reportId is string
          && canManagerEditReport(resource.data.reportId)
          && resource.data.branchId == getReportData(resource.data.reportId).branchId);
    }

    // ─── reportComments ──────────────────────────────────────────────────
    // Only the admin or the active manager who owns the report's branch can read comments.
    match /reportComments/{commentId} {
      allow read: if isAdmin() ||
        (isActiveManager()
          && get(/databases/$(database)/documents/dailyReports/$(resource.data.reportId)).data.branchId
             in getUserData().branchIds);
      allow create: if isActive()
        && request.resource.data.authorUid == uid()
        && request.resource.data.reportId is string
        && request.resource.data.content is string
        && (isAdmin() ||
          (isActiveManager()
            && getReportData(request.resource.data.reportId).branchId in getUserData().branchIds));
      allow update, delete: if isAdmin();
    }

    // ─── trainers (전사 공용 — 지점 소속 없음) ─────────────────────────────────
    // 트레이너 프로필 자체에는 branchIds를 두지 않는다. 지점 구분은 trainerSessions에만 존재.
    function validTrainerCreate(data) {
      return data.keys().hasOnly([
          'name', 'phoneLast4', 'identifierMemo', 'firstRegisteredBranchId',
          'active', 'createdBy', 'createdAt', 'updatedAt'
        ])
        && data.name is string && data.name.size() > 0
        && data.active == true
        && data.createdBy == uid();
    }

    function validTrainerUpdate(data) {
      return data.diff(resource.data).affectedKeys()
        .hasOnly(['name', 'phoneLast4', 'identifierMemo', 'active', 'updatedAt']);
    }

    match /trainers/{trainerId} {
      // 전체 active 사용자(admin, branch_manager)가 전사 공용 목록을 조회·검색할 수 있다.
      allow read: if isActive();
      // branch_manager도 신규 트레이너 등록은 가능하다 (지점 연결 절차 없음).
      allow create: if isActive() && validTrainerCreate(request.resource.data);
      // 이름/전화번호 뒤 4자리/식별 메모/active 변경은 admin만 가능.
      // branch_manager는 다른 트레이너 정보를 수정하거나 active를 바꿀 수 없다.
      allow update: if isAdmin() && validTrainerUpdate(request.resource.data);
      // 트레이너 전체 삭제는 허용하지 않는다 — 비활성 처리(active:false)로만 관리한다.
      allow delete: if false;
    }

    // ─── trainerSessions (트레이너의 지점·날짜별 세션 기록) ────────────────────
    // Doc ID: {branchId}_{date}_{trainerId}
    // Admin: 전체 지점 조회/수정. branch_manager: 본인 담당 지점 세션만 입력·수정 가능.
    match /trainerSessions/{sessionId} {
      allow read: if isAdmin() ||
        (isActiveManager() && resource.data.branchId in getUserData().branchIds);

      allow create: if isAdmin() ||
        (isActiveManager()
          && request.resource.data.branchId in getUserData().branchIds
          && request.resource.data.createdBy == uid()
          && sessionId == request.resource.data.branchId + '_' +
             request.resource.data.date + '_' + request.resource.data.trainerId);

      // 지점/트레이너/날짜/작성자는 생성 이후 변경할 수 없다 (다른 지점 세션으로 재귀속 방지).
      allow update: if isAdmin() ||
        (isActiveManager()
          && resource.data.branchId in getUserData().branchIds
          && request.resource.data.branchId == resource.data.branchId
          && request.resource.data.trainerId == resource.data.trainerId
          && request.resource.data.date == resource.data.date
          && request.resource.data.createdBy == resource.data.createdBy);

      allow delete: if isAdmin();
    }

    // ─── trainerDailyReports (deprecated — 과거 지점별 세션 데이터 보존용) ─────
    // 신규 코드에서는 사용하지 않는다. 기존 문서는 삭제하지 않고 그대로 둔다.
    // Doc ID: {branchId}_{reportDate}_{trainerId}
    match /trainerDailyReports/{reportId} {
      allow read: if isAdmin() ||
        (isActiveManager() && resource.data.branchId in getUserData().branchIds);
      allow create, update: if isAdmin() ||
        (isActiveManager()
          && request.resource.data.branchId in getUserData().branchIds
          && request.resource.data.writerUid == uid());
      allow delete: if isAdmin();
    }

    // ─── trainerImportBatches (수기 명단 일괄 등록 — 중복 승인 방지 기록) ─────────
    // 실제 등록 처리는 commitTrainerRosterImport 서버 함수(Admin SDK)만 수행하므로
    // 클라이언트 쓰기는 항상 차단한다. admin은 처리 이력 조회만 가능하다.
    match /trainerImportBatches/{batchId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── managerInvites ───────────────────────────────────────────────────────
    match /managerInvites/{docId} {
      allow read, write: if isAdmin();
    }

    // ─── member CRM ───────────────────────────────────────────────────────────
    match /members/{memberId} {
      allow read: if isAdmin() ||
        (isActiveManager() && resource.data.branchId in getUserData().branchIds);
      allow create: if validMemberData(request.resource.data)
        && (isAdmin() ||
          (isActiveManager() && request.resource.data.branchId in getUserData().branchIds));
      allow update: if validMemberData(request.resource.data)
        && (isAdmin() ||
          (isActiveManager()
            && resource.data.branchId in getUserData().branchIds
            && request.resource.data.branchId == resource.data.branchId));
      allow delete: if isAdmin();
    }

    match /memberSatisfactionSurveys/{surveyId} {
      allow read: if isAdmin() ||
        (isActiveManager() && resource.data.branchId in getUserData().branchIds);
      allow create: if validSatisfactionData(request.resource.data)
        && (isAdmin() ||
          (isActiveManager() && request.resource.data.branchId in getUserData().branchIds));
      allow update: if validSatisfactionData(request.resource.data)
        && (isAdmin() ||
          (isActiveManager()
            && resource.data.branchId in getUserData().branchIds
            && request.resource.data.branchId == resource.data.branchId));
      allow delete: if isAdmin();
    }

    match /memberImportJobs/{jobId} {
      allow read: if isAdmin() ||
        (isActiveManager() && resource.data.branchId in getUserData().branchIds);
      allow create: if validMemberImportJobData(request.resource.data)
        && ((isAdmin() && request.resource.data.uploadedByRole == 'admin') ||
          (isActiveManager()
            && request.resource.data.uploadedByRole == 'branch_manager'
            && request.resource.data.branchId in getUserData().branchIds));
      allow update, delete: if isAdmin();
    }

    // ─── auditLogs ────────────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update, delete: if false;
    }
  }
}
